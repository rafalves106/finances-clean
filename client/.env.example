# API base used by production build (Vercel/static hosting)
# Example: https://finance-api.onrender.com
VITE_API_BASE_URL=

# API proxy target used only by Vite dev server (npm run dev)
# Local backend:
VITE_PROXY_TARGET=http://localhost:5010
# Docker backend:
# VITE_PROXY_TARGET=http://backend:5000
